# Copy this file to `.env` and fill in real values for local development.
# Do NOT commit `.env`. In Render, set these as Environment Variables.

# --- Django ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
# Comma-separated list of allowed hosts. Add Render hostname in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# In dev (DEBUG=True with settings.dev), SQLite is used and this is ignored.
# In prod, REQUIRED. Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# --- Frontend ---
# Used for OAuth redirects and CORS origin allowlisting.
FRONTEND_URL=http://localhost:3000

# Comma-separated lists; one entry per allowed origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Twitch OAuth ---
# Obtain credentials at https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:8000/api/auth/twitch/callback/

# --- Liquipedia API (used in PR #2) ---
# Required by Liquipedia ToS — must identify your app and contact.
LIQUIPEDIA_USER_AGENT=CS2MajorCalculator/1.0 (https://github.com/AlexHerrerias/CS2MajorCalculator)
